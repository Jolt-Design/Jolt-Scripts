{
  "name": "@joltdesign/scripts",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "bin": {
    "jolt": "./dist/cli.js"
  },
  "version": "1.5.1",
  "type": "module",
  "jira-prepare-commit-msg": {
    "messagePattern": "$J $M",
    "ignoredBranchesPattern": "^(dependabot/|renovate/)"
  },
  "files": [
    "/dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && pnpm run generate-schema",
    "clean": "rimraf dist",
    "debug": "node --inspect-brk ./dist/cli.js",
    "generate-schema": "node ./scripts/generate-schema.js && pnpm lint --write jolt-config.schema.json",
    "jolt": "node ./dist/cli.js",
    "lint": "biome check",
    "fmt": "biome format",
    "prepack": "run build",
    "setup": "jolt prepare",
    "test": "vitest",
    "test:coverage": "vitest --coverage.enabled=true",
    "test:run": "vitest run",
    "watch": "tsc -w"
  },
  "dependencies": {
    "ansis": "^4.3.1",
    "change-case": "^5.4.4",
    "clipanion": "^4.0.0-rc.4",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "object-resolve-path": "^1.1.1",
    "typanion": "^3.14.0",
    "which": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^24.13.2",
    "@types/which": "^3.0.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
